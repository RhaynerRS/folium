<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:LexicastUi.Models"
             xmlns:views="using:LexicastUi.Views"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="820"
             x:Class="LexicastUi.Views.NewTranslationView">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1160" Margin="32,36,32,80" Spacing="0">

            <views:Breadcrumb x:Name="Crumbs" Margin="0,0,0,28" />

            <StackPanel MaxWidth="640" HorizontalAlignment="Left" Spacing="0">
                <TextBlock Text="New Translation" FontSize="28" FontWeight="Black" LetterSpacing="-0.4" Margin="0,0,0,6" />
                <TextBlock Text="Upload an EPUB and configure how it should be translated."
                           Classes="MutedText" FontSize="14" Margin="0,0,0,32" />

                <StackPanel Spacing="26">

                    <!-- File input -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="EPUB file" Classes="FieldLabel" />
                        <Border x:Name="FileDropZone" Classes="FileDropZone" Tapped="FileDropZone_Tapped">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Grid.Column="0" Classes="FileIconBadge">
                                    <TextBlock Text="E" Foreground="White" FontWeight="Black" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="FileNameText" Text="No file selected" FontSize="14" FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="FileHelperText" Text="Click to choose an .epub file from your computer"
                                               Classes="MutedText" FontSize="12.5" Margin="0,2,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="Browse" Classes="AccentLink" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Target language -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Target language" Classes="FieldLabel" />
                        <ComboBox x:Name="LanguageBox" HorizontalAlignment="Stretch" ItemsSource="{x:Static models:Language.All}"
                                  SelectedIndex="0" />
                    </StackPanel>

                    <!-- Instructions -->
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Instructions for the translator" Classes="FieldLabel" />
                            <TextBlock Text="(optional)" Classes="MutedText" FontSize="13" />
                        </StackPanel>
                        <TextBox x:Name="UserPromptBox"
                                 PlaceholderText="e.g. Keep character names untranslated, preserve footnote markers, use formal tone…"
                                 AcceptsReturn="True" TextWrapping="Wrap" Height="76" />
                    </StackPanel>

                    <!-- Concurrency -->
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Concurrent LLM sessions" Classes="FieldLabel" />
                            <TextBlock Grid.Column="1" x:Name="ConcurrencyValueText" Text="3" FontSize="15" FontWeight="Black"
                                       Classes="AccentText" />
                        </Grid>
                        <Slider x:Name="ConcurrencySlider" Minimum="1" Maximum="10" TickFrequency="1"
                                IsSnapToTickEnabled="True" Value="3" ValueChanged="ConcurrencySlider_ValueChanged" />
                        <TextBlock Text="Number of parallel sessions calling the LLM. Higher values translate faster but increase API load."
                                   Classes="MutedText" FontSize="12.5" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Submit kind -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Submit kind" Classes="FieldLabel" />
                        <Grid ColumnDefinitions="*,*,*" Margin="0,8,0,0">
                            <Button Grid.Column="0" x:Name="ReplaceButton" Classes="SubmitKindOption" Margin="0,0,5,0"
                                    Click="ReplaceButton_Click">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="REPLACE" Classes="SubmitKindTitle" />
                                    <TextBlock Text="Replace the original text entirely with the translation."
                                               Classes="SubmitKindDescription" TextWrapping="Wrap" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" x:Name="AppendTextButton" Classes="SubmitKindOption" Margin="5,0"
                                    Click="AppendTextButton_Click">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="APPEND_TEXT" Classes="SubmitKindTitle" />
                                    <TextBlock Text="Insert translated text inline after each paragraph."
                                               Classes="SubmitKindDescription" TextWrapping="Wrap" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" x:Name="AppendBlockButton" Classes="SubmitKindOption Active" Margin="5,0,0,0"
                                    Click="AppendBlockButton_Click">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="APPEND_BLOCK" Classes="SubmitKindTitle" />
                                    <TextBlock Text="Append translated content as a new block after each section."
                                               Classes="SubmitKindDescription" TextWrapping="Wrap" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <TextBlock Text="Defaults to APPEND_BLOCK if omitted." Classes="MutedText" FontSize="12" />
                    </StackPanel>

                    <Border x:Name="ErrorBanner" Classes="Banner Error" IsVisible="False">
                        <TextBlock x:Name="ErrorText" Foreground="#C1443B" TextWrapping="Wrap" />
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                        <Button x:Name="SubmitButton" Content="Start translation" Classes="accent"
                                Click="SubmitButton_Click" IsEnabled="False" />
                        <Button Content="Cancel" Classes="GhostButton" Click="CancelButton_Click" />
                        <ProgressBar x:Name="SubmitProgressBar" Width="20" Height="20" IsIndeterminate="True" IsVisible="False" />
                    </StackPanel>

                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
