<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="using:LexicastUi.Views"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="600"
             x:Class="LexicastUi.Views.SuccessView">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1160" Margin="32,36,32,80" Spacing="0">

            <views:Breadcrumb x:Name="Crumbs" Margin="0,0,0,28" />

            <StackPanel MaxWidth="560" HorizontalAlignment="Center" Spacing="0" Margin="0,40,0,0">

                <Border Classes="SuccessBadge" Margin="0,0,0,24">
                    <TextBlock Text="&#x2713;" FontSize="28" FontWeight="Black" Foreground="#1E9E6B"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <TextBlock Text="Translation complete" FontSize="24" FontWeight="Black" HorizontalAlignment="Center"
                           Margin="0,0,0,8" />
                <TextBlock x:Name="SubtitleText" Classes="MutedText" FontSize="14" HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,32" />

                <Border Classes="Card" Padding="24">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" Classes="FileIconBadge" Width="46" Height="46">
                            <TextBlock Text="E" Foreground="White" FontWeight="Black" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                            <TextBlock x:Name="FileNameText" FontSize="14" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="MetaLineText" Classes="MutedText" FontSize="12.5" Margin="0,2,0,0" />
                        </StackPanel>
                        <Button Grid.Column="2" x:Name="DownloadButton" Content="Download" Classes="accent"
                                VerticalAlignment="Center" Click="DownloadButton_Click" />
                    </Grid>
                </Border>

                <Border x:Name="ErrorBanner" Classes="Banner Error" IsVisible="False" Margin="0,20,0,0">
                    <TextBlock x:Name="ErrorText" Foreground="#C1443B" TextWrapping="Wrap" />
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" Margin="0,24,0,0">
                    <TextBlock Text="← Back to translations" Classes="AccentLink" Tapped="BackLink_Tapped" />
                    <ProgressBar x:Name="DownloadProgressBar" Width="18" Height="18" IsIndeterminate="True" IsVisible="False" />
                </StackPanel>

            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
