<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:LexicastUi.Models"
             xmlns:views="using:LexicastUi.Views"
             mc:Ignorable="d" d:DesignWidth="1160" d:DesignHeight="720"
             x:Class="LexicastUi.Views.TranslationsView">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1160" Margin="32,36,32,80" Spacing="0">

            <views:Breadcrumb x:Name="Crumbs" Margin="0,0,0,28" />

            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,28">
                <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Bottom">
                    <TextBlock Text="Translations" FontSize="30" FontWeight="Black" LetterSpacing="-0.4" />
                    <TextBlock x:Name="JobCountText" Classes="MutedText" FontSize="14" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Bottom">
                    <Border Classes="ViewToggle">
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <Button x:Name="TableViewButton" Content="Table" Classes="ViewToggleButton"
                                    Click="TableViewButton_Click" />
                            <Button x:Name="CardsViewButton" Content="Cards" Classes="ViewToggleButton"
                                    Click="CardsViewButton_Click" />
                        </StackPanel>
                    </Border>
                    <Button Classes="accent" Content="+ New Translation" Click="NewTranslationButton_Click" />
                </StackPanel>
            </Grid>

            <!-- TABLE VIEW -->
            <Border x:Name="TableCard" Classes="Card" Padding="0" ClipToBounds="True">
                <StackPanel>
                    <Grid ColumnDefinitions="2.4*,1.3*,1.1*,1.2*,1.3*,1*,1*" Classes="TableHeaderRow">
                        <TextBlock Grid.Column="0" Text="Name" Classes="TableHeader" />
                        <TextBlock Grid.Column="1" Text="Job ID" Classes="TableHeader" />
                        <TextBlock Grid.Column="2" Text="Status" Classes="TableHeader" />
                        <TextBlock Grid.Column="3" Text="Language" Classes="TableHeader" />
                        <TextBlock Grid.Column="4" Text="Submit Kind" Classes="TableHeader" />
                        <TextBlock Grid.Column="5" Text="Created" Classes="TableHeader" />
                        <TextBlock Grid.Column="6" Text="Action" Classes="TableHeader" HorizontalAlignment="Right" />
                    </Grid>
                    <ItemsControl x:Name="TableJobsItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:JobRow">
                                <Border Classes="TableJobRow" Classes.Clickable="{Binding IsClickable}"
                                        PointerPressed="JobRow_PointerPressed">
                                    <Grid ColumnDefinitions="2.4*,1.3*,1.1*,1.2*,1.3*,1*,1*">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Classes="JobName" />
                                        <TextBlock Grid.Column="1" Text="{Binding JobId}" Classes="JobId" />
                                        <Border Grid.Column="2" Classes="StatusPill"
                                                Background="{Binding StatusBackground}" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <Ellipse Width="6" Height="6" Fill="{Binding StatusForeground}"
                                                         Classes.Pulsing="{Binding Pulsing}" />
                                                <TextBlock Text="{Binding StatusLabel}"
                                                           Foreground="{Binding StatusForeground}" Classes="StatusLabel" />
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="{Binding Language}" Classes="JobMeta" />
                                        <Border Grid.Column="4" Classes="TagPill" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding SubmitKindLabel}" Classes="TagLabel" />
                                        </Border>
                                        <TextBlock Grid.Column="5" Text="{Binding Created}" Classes="JobMeta" />
                                        <TextBlock Grid.Column="6" Text="{Binding ActionLabel}" Classes="ActionLabel"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- CARD GRID VIEW -->
            <ItemsControl x:Name="CardJobsItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:JobRow">
                        <Border Classes="Card JobCard" Classes.Clickable="{Binding IsClickable}"
                                Width="280" Margin="0,0,18,18" Padding="20"
                                PointerPressed="JobRow_PointerPressed">
                            <StackPanel Spacing="14">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="15" FontWeight="Bold"
                                               TextWrapping="Wrap" />
                                    <Border Grid.Column="1" Classes="StatusPill" Background="{Binding StatusBackground}"
                                            VerticalAlignment="Top">
                                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                            <Ellipse Width="5" Height="5" Fill="{Binding StatusForeground}"
                                                     Classes.Pulsing="{Binding Pulsing}" />
                                            <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusForeground}"
                                                       Classes="StatusLabel" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding JobId}" Classes="JobId" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Classes="TagPill">
                                        <TextBlock Text="{Binding Language}" Classes="TagLabel" />
                                    </Border>
                                    <Border Classes="TagPill">
                                        <TextBlock Text="{Binding SubmitKindLabel}" Classes="TagLabel" />
                                    </Border>
                                </StackPanel>
                                <Border Classes="CardFooterDivider">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Created}" Classes="JobMeta" />
                                        <TextBlock Grid.Column="1" Text="{Binding ActionLabel}" Classes="ActionLabel" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
